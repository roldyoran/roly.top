{
  "name": "shorturl",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "packageManager": "bun@1.2.15",
  "scripts": {
    "dev:front": "bun --cwd frontend dev",
    "dev:back": "bun --cwd backend dev",
    "build:front": "bun --cwd frontend build",
    "build:back": "bun --cwd backend build",
    "build": "bun run build:front && bun run build:back",
    "deploy": "bun run build:front && bun --cwd backend run deploy",
    "check:front": "bun --cwd frontend check",
    "format:front": "bun --cwd frontend format",
    "lint:front": "bun --cwd frontend lint"
  },
  "devDependencies": {
    "shadcn-vue": "^2.4.3"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4"
  }
}
